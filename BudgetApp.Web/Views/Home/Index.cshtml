@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center my-5">
    <h1 class="display-4">Welcome to BudgetApp</h1>
    <p class="lead">Manage your personal finances easily and efficiently.</p>
</div>

@* Sekcja z podsumowaniem statystyk *@
<div class="row text-center">
    <div class="col-md-6 mb-4">
        <div class="card bg-light border-primary h-100">
            <div class="card-body">
                <h5 class="card-title text-primary">Total Expenses</h5>
                <p class="card-text display-6 fw-bold">@ViewBag.TotalExpenses USD</p>
                <a asp-controller="Expenses" asp-action="Index" class="btn btn-outline-primary btn-sm">View Expenses</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card bg-light border-success h-100">
            <div class="card-body">
                <h5 class="card-title text-success">Total Categories</h5>
                <p class="card-text display-6 fw-bold">@ViewBag.TotalCategories</p>
                <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-success btn-sm">View Categories</a>
            </div>
        </div>
    </div>
</div>